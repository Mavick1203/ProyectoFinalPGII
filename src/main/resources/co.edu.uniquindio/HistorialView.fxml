<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.viewControllers.HistorialViewController"
            prefHeight="600.0" prefWidth="720.0"
            style="-fx-background-color: #f5f5f0;">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- Encabezado -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: white;
                     -fx-border-color: #e0e0d8; -fx-border-width: 0 0 0.5 0;
                     -fx-padding: 14 24;">
            <VBox spacing="2">
                <Label text="Mis compras"
                       style="-fx-font-size: 18; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>
                <Label text="Historial de todas tus compras"
                       style="-fx-font-size: 13; -fx-text-fill: #888780;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Volver" onAction="#onVolver"
                    style="-fx-font-size: 13; -fx-background-color: transparent;
                           -fx-text-fill: #5f5e5a; -fx-border-color: #d3d1c7;
                           -fx-border-radius: 8; -fx-background-radius: 8;
                           -fx-pref-height: 32; -fx-cursor: hand;"/>
        </HBox>

        <!-- Cuerpo -->
        <HBox spacing="20" style="-fx-padding: 24;" VBox.vgrow="ALWAYS">

            <!-- Lista de compras -->
            <VBox spacing="12" HBox.hgrow="ALWAYS">
                <Label text="Compras realizadas"
                       style="-fx-font-size: 14; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                <ListView fx:id="lstCompras"
                          VBox.vgrow="ALWAYS"
                          style="-fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                                 -fx-border-radius: 8; -fx-background-radius: 8;
                                 -fx-font-size: 13;"/>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Button text="Cancelar compra seleccionada"
                            onAction="#onCancelarCompra"
                            style="-fx-pref-height: 36; -fx-font-size: 13; -fx-font-weight: 500;
                                   -fx-background-color: #a32d2d; -fx-text-fill: white;
                                   -fx-border-radius: 8; -fx-background-radius: 8;
                                   -fx-padding: 0 18; -fx-cursor: hand;"/>
                    <Label fx:id="lblMensaje" text=""
                           style="-fx-font-size: 13; -fx-text-fill: #a32d2d;"/>
                </HBox>
            </VBox>

            <!-- Panel de detalle -->
            <VBox prefWidth="260" spacing="12">
                <Label text="Detalle"
                       style="-fx-font-size: 14; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                <VBox spacing="0"
                      VBox.vgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                             -fx-border-radius: 8; -fx-background-radius: 8;
                             -fx-padding: 20;">
                    <Label fx:id="lblDetalle" text="Selecciona una compra para ver el detalle."
                           wrapText="true"
                           style="-fx-font-size: 13; -fx-text-fill: #5f5e5a; -fx-line-spacing: 4;"/>
                </VBox>
            </VBox>
        </HBox>
    </VBox>
</AnchorPane>
