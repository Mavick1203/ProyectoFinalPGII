<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.viewControllers.AdminViewController"
            prefHeight="720.0" prefWidth="960.0"
            style="-fx-background-color: #f5f5f0;">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- Barra superior -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #2c2c2a;
                     -fx-padding: 14 24;">
            <Label text="EventosUQ — Panel de administración"
                   style="-fx-font-size: 15; -fx-font-weight: 500; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblMensaje" text=""
                   style="-fx-font-size: 13; -fx-text-fill: #9FE1CB;"/>
            <Button text="Cerrar sesión" onAction="#onCerrarSesion"
                    style="-fx-font-size: 13; -fx-background-color: transparent;
                           -fx-text-fill: #f09595; -fx-border-color: #f09595;
                           -fx-border-radius: 8; -fx-background-radius: 8;
                           -fx-pref-height: 30; -fx-cursor: hand;"/>
        </HBox>

        <!-- Tabs principales -->
        <TabPane VBox.vgrow="ALWAYS"
                 style="-fx-tab-min-height: 40; -fx-font-size: 13;">

            <!-- ── Tab Eventos ── -->
            <Tab text="Eventos" closable="false">
                <VBox spacing="16" style="-fx-padding: 20;">

                    <!-- Métricas rápidas de eventos -->
                    <HBox spacing="12">
                        <Label text="Gestión de eventos"
                               style="-fx-font-size: 16; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>
                    </HBox>

                    <ListView fx:id="lstEventos"
                              prefHeight="340"
                              style="-fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                                     -fx-border-radius: 8; -fx-background-radius: 8;
                                     -fx-font-size: 13;"/>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="Publicar" onAction="#onPublicarEvento"
                                style="-fx-pref-height: 34; -fx-font-size: 13; -fx-font-weight: 500;
                                       -fx-background-color: #0f6e56; -fx-text-fill: white;
                                       -fx-border-radius: 8; -fx-background-radius: 8;
                                       -fx-padding: 0 16; -fx-cursor: hand;"/>
                        <Button text="Pausar" onAction="#onPausarEvento"
                                style="-fx-pref-height: 34; -fx-font-size: 13; -fx-font-weight: 500;
                                       -fx-background-color: #ba7517; -fx-text-fill: white;
                                       -fx-border-radius: 8; -fx-background-radius: 8;
                                       -fx-padding: 0 16; -fx-cursor: hand;"/>
                        <Button text="Cancelar" onAction="#onCancelarEvento"
                                style="-fx-pref-height: 34; -fx-font-size: 13; -fx-font-weight: 500;
                                       -fx-background-color: #a32d2d; -fx-text-fill: white;
                                       -fx-border-radius: 8; -fx-background-radius: 8;
                                       -fx-padding: 0 16; -fx-cursor: hand;"/>
                        <Button text="Eliminar" onAction="#onEliminarEvento"
                                style="-fx-pref-height: 34; -fx-font-size: 13;
                                       -fx-background-color: transparent;
                                       -fx-text-fill: #5f5e5a; -fx-border-color: #d3d1c7;
                                       -fx-border-radius: 8; -fx-background-radius: 8;
                                       -fx-padding: 0 16; -fx-cursor: hand;"/>
                        <Label fx:id="lblEstadoEvento" text=""
                               style="-fx-font-size: 13; -fx-text-fill: #0f6e56;"/>
                    </HBox>
                </VBox>
            </Tab>

            <!-- ── Tab Usuarios ── -->
            <Tab text="Usuarios" closable="false">
                <VBox spacing="16" style="-fx-padding: 20;">
                    <Label text="Gestión de usuarios"
                           style="-fx-font-size: 16; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                    <ListView fx:id="lstUsuarios"
                              prefHeight="380"
                              style="-fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                                     -fx-border-radius: 8; -fx-background-radius: 8;
                                     -fx-font-size: 13;"/>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="Eliminar usuario" onAction="#onEliminarUsuario"
                                style="-fx-pref-height: 34; -fx-font-size: 13; -fx-font-weight: 500;
                                       -fx-background-color: #a32d2d; -fx-text-fill: white;
                                       -fx-border-radius: 8; -fx-background-radius: 8;
                                       -fx-padding: 0 18; -fx-cursor: hand;"/>
                        <Label fx:id="lblEstadoUsuario" text=""
                               style="-fx-font-size: 13; -fx-text-fill: #5f5e5a;"/>
                    </HBox>
                </VBox>
            </Tab>

            <!-- ── Tab Compras ── -->
            <Tab text="Compras" closable="false">
                <VBox spacing="16" style="-fx-padding: 20;">
                    <Label text="Gestión de compras"
                           style="-fx-font-size: 16; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                    <ListView fx:id="lstCompras"
                              prefHeight="360"
                              style="-fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                                     -fx-border-radius: 8; -fx-background-radius: 8;
                                     -fx-font-size: 13;"/>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="Cancelar compra" onAction="#onCancelarCompra"
                                style="-fx-pref-height: 34; -fx-font-size: 13; -fx-font-weight: 500;
                                       -fx-background-color: #a32d2d; -fx-text-fill: white;
                                       -fx-border-radius: 8; -fx-background-radius: 8;
                                       -fx-padding: 0 18; -fx-cursor: hand;"/>
                        <Button text="Reembolsar" onAction="#onReembolsarCompra"
                                style="-fx-pref-height: 34; -fx-font-size: 13; -fx-font-weight: 500;
                                       -fx-background-color: #185fa5; -fx-text-fill: white;
                                       -fx-border-radius: 8; -fx-background-radius: 8;
                                       -fx-padding: 0 18; -fx-cursor: hand;"/>
                        <Label fx:id="lblEstadoCompra" text=""
                               style="-fx-font-size: 13; -fx-text-fill: #5f5e5a;"/>
                    </HBox>
                </VBox>
            </Tab>

            <!-- ── Tab Métricas ── -->
            <Tab text="Métricas" closable="false">
                <VBox spacing="20" style="-fx-padding: 24;">
                    <Label text="Métricas de la plataforma"
                           style="-fx-font-size: 16; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                    <!-- Cards de métricas -->
                    <GridPane hgap="16" vgap="16">
                        <VBox GridPane.columnIndex="0" GridPane.rowIndex="0"
                              spacing="6"
                              style="-fx-background-color: white;
                                     -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                                     -fx-border-radius: 8; -fx-background-radius: 8;
                                     -fx-padding: 16; -fx-pref-width: 200;">
                            <Label text="Total ventas"
                                   style="-fx-font-size: 12; -fx-text-fill: #888780;"/>
                            <Label fx:id="lblTotalVentas" text="—"
                                   style="-fx-font-size: 24; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>
                        </VBox>

                        <VBox GridPane.columnIndex="1" GridPane.rowIndex="0"
                              spacing="6"
                              style="-fx-background-color: white;
                                     -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                                     -fx-border-radius: 8; -fx-background-radius: 8;
                                     -fx-padding: 16; -fx-pref-width: 200;">
                            <Label text="Ingreso total"
                                   style="-fx-font-size: 12; -fx-text-fill: #888780;"/>
                            <Label fx:id="lblIngresoTotal" text="—"
                                   style="-fx-font-size: 24; -fx-font-weight: 500; -fx-text-fill: #0f6e56;"/>
                        </VBox>

                        <VBox GridPane.columnIndex="2" GridPane.rowIndex="0"
                              spacing="6"
                              style="-fx-background-color: white;
                                     -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                                     -fx-border-radius: 8; -fx-background-radius: 8;
                                     -fx-padding: 16; -fx-pref-width: 200;">
                            <Label text="Cancelaciones"
                                   style="-fx-font-size: 12; -fx-text-fill: #888780;"/>
                            <Label fx:id="lblTotalCancelaciones" text="—"
                                   style="-fx-font-size: 24; -fx-font-weight: 500; -fx-text-fill: #a32d2d;"/>
                        </VBox>

                        <VBox GridPane.columnIndex="3" GridPane.rowIndex="0"
                              spacing="6"
                              style="-fx-background-color: white;
                                     -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                                     -fx-border-radius: 8; -fx-background-radius: 8;
                                     -fx-padding: 16; -fx-pref-width: 200;">
                            <Label text="Tasa cancelación"
                                   style="-fx-font-size: 12; -fx-text-fill: #888780;"/>
                            <Label fx:id="lblTasaCancelacion" text="—"
                                   style="-fx-font-size: 24; -fx-font-weight: 500; -fx-text-fill: #ba7517;"/>
                        </VBox>
                    </GridPane>

                    <Button text="Actualizar métricas" onAction="#onActualizarMetricas"
                            style="-fx-pref-height: 36; -fx-font-size: 13; -fx-font-weight: 500;
                                   -fx-background-color: #2c2c2a; -fx-text-fill: white;
                                   -fx-border-radius: 8; -fx-background-radius: 8;
                                   -fx-padding: 0 20; -fx-cursor: hand;"/>
                </VBox>
            </Tab>

        </TabPane>
    </VBox>
</AnchorPane>
