<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.viewControllers.ReporteViewController"
            prefHeight="600.0" prefWidth="700.0"
            style="-fx-background-color: #f5f5f0;">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: white;
                     -fx-border-color: #e0e0d8; -fx-border-width: 0 0 0.5 0;
                     -fx-padding: 14 24;">
            <VBox spacing="2">
                <Label text="Reportes Operativos"
                       style="-fx-font-size: 18; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>
                <Label text="Exporta reportes en CSV o PDF"
                       style="-fx-font-size: 13; -fx-text-fill: #888780;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Volver" onAction="#onVolver"
                    style="-fx-font-size: 13; -fx-background-color: transparent;
                           -fx-text-fill: #5f5e5a; -fx-border-color: #d3d1c7;
                           -fx-border-radius: 8; -fx-background-radius: 8;
                           -fx-pref-height: 32; -fx-cursor: hand;"/>
        </HBox>

        <VBox spacing="20" style="-fx-padding: 24;">

            <VBox spacing="16"
                  style="-fx-background-color: white;
                         -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                         -fx-border-radius: 8; -fx-background-radius: 8;
                         -fx-padding: 20;">

                <Label text="Configuración del reporte"
                       style="-fx-font-size: 15; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Tipo de reporte"
                               style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                        <ComboBox fx:id="cmbTipoReporte" maxWidth="Infinity"
                                  style="-fx-pref-height: 34; -fx-font-size: 13;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Formato"
                               style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                        <ComboBox fx:id="cmbFormato" maxWidth="Infinity"
                                  style="-fx-pref-height: 34; -fx-font-size: 13;"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Fecha desde"
                               style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                        <DatePicker fx:id="dateFiltroDesde" maxWidth="Infinity"
                                    style="-fx-pref-height: 34; -fx-font-size: 13;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Fecha hasta"
                               style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                        <DatePicker fx:id="dateFiltroHasta" maxWidth="Infinity"
                                    style="-fx-pref-height: 34; -fx-font-size: 13;"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="ID Evento (solo para reporte de ocupación)"
                           style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                    <TextField fx:id="txtIdEvento"
                               promptText="ID del evento"
                               style="-fx-pref-height: 34; -fx-font-size: 13;
                                      -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 0 10;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Ruta de salida"
                           style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                    <HBox spacing="10">
                        <TextField fx:id="txtRutaSalida"
                                   promptText="Ej: C:/reportes/ventas.csv"
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-pref-height: 34; -fx-font-size: 13;
                                          -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 0 10;"/>
                        <Button text="Examinar" onAction="#onExaminar"
                                style="-fx-pref-height: 34; -fx-font-size: 13;
                                       -fx-background-color: transparent;
                                       -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                       -fx-background-radius: 8; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <Button text="Exportar reporte" onAction="#onExportar"
                        style="-fx-pref-height: 36; -fx-font-size: 13; -fx-font-weight: 500;
                               -fx-background-color: #0f6e56; -fx-text-fill: white;
                               -fx-border-radius: 8; -fx-background-radius: 8;
                               -fx-padding: 0 20; -fx-cursor: hand;"/>
            </VBox>

            <Label fx:id="lblMensaje" text="" wrapText="true"
                   style="-fx-font-size: 13;"/>
        </VBox>
    </VBox>
</AnchorPane>