<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.viewControllers.IncidenciaViewController"
            prefHeight="640.0" prefWidth="800.0"
            style="-fx-background-color: #f5f5f0;">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: white;
                     -fx-border-color: #e0e0d8; -fx-border-width: 0 0 0.5 0;
                     -fx-padding: 14 24;">
            <VBox spacing="2">
                <Label text="Incidencias"
                       style="-fx-font-size: 18; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>
                <Label text="Registra y consulta incidencias operativas"
                       style="-fx-font-size: 13; -fx-text-fill: #888780;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Volver" onAction="#onVolver"
                    style="-fx-font-size: 13; -fx-background-color: transparent;
                           -fx-text-fill: #5f5e5a; -fx-border-color: #d3d1c7;
                           -fx-border-radius: 8; -fx-background-radius: 8;
                           -fx-pref-height: 32; -fx-cursor: hand;"/>
        </HBox>

        <HBox spacing="20" style="-fx-padding: 24;" VBox.vgrow="ALWAYS">

            <!-- Panel registro -->
            <VBox spacing="16" prefWidth="300">
                <Label text="Registrar incidencia"
                       style="-fx-font-size: 15; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                <VBox spacing="14"
                      style="-fx-background-color: white;
                             -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                             -fx-border-radius: 8; -fx-background-radius: 8;
                             -fx-padding: 20;">

                    <VBox spacing="6">
                        <Label text="Tipo"
                               style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                        <ComboBox fx:id="cmbTipo" maxWidth="Infinity"
                                  style="-fx-pref-height: 34; -fx-font-size: 13;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Descripción"
                               style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                        <TextArea fx:id="txtDescripcion"
                                  promptText="Describe la incidencia..."
                                  prefHeight="80"
                                  style="-fx-font-size: 13;
                                         -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                         -fx-background-radius: 8; -fx-padding: 8 10;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="ID entidad afectada"
                               style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                        <TextField fx:id="txtIdEntidad"
                                   promptText="ID del evento o compra"
                                   style="-fx-pref-height: 34; -fx-font-size: 13;
                                          -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 0 10;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Tipo de entidad"
                               style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                        <ComboBox fx:id="cmbTipoEntidad" maxWidth="Infinity"
                                  style="-fx-pref-height: 34; -fx-font-size: 13;"/>
                    </VBox>

                    <Button text="Registrar" onAction="#onRegistrar"
                            maxWidth="Infinity"
                            style="-fx-pref-height: 34; -fx-font-size: 13; -fx-font-weight: 500;
                                   -fx-background-color: #2c2c2a; -fx-text-fill: white;
                                   -fx-border-radius: 8; -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>

                    <Label fx:id="lblMensaje" text="" wrapText="true"
                           style="-fx-font-size: 12;"/>
                </VBox>
            </VBox>

            <!-- Panel consulta -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <Label text="Consultar incidencias"
                       style="-fx-font-size: 15; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                <HBox spacing="12" alignment="CENTER_LEFT"
                      style="-fx-background-color: white;
                             -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                             -fx-border-radius: 8; -fx-background-radius: 8;
                             -fx-padding: 14 16;">
                    <ComboBox fx:id="cmbFiltroTipo" prefWidth="180"
                              style="-fx-pref-height: 34; -fx-font-size: 13;"/>
                    <DatePicker fx:id="dateFiltroDesde"
                                promptText="Desde"
                                style="-fx-pref-height: 34; -fx-font-size: 13;"/>
                    <DatePicker fx:id="dateFiltroHasta"
                                promptText="Hasta"
                                style="-fx-pref-height: 34; -fx-font-size: 13;"/>
                    <Button text="Filtrar" onAction="#onFiltrar"
                            style="-fx-pref-height: 34; -fx-font-size: 13; -fx-font-weight: 500;
                                   -fx-background-color: #2c2c2a; -fx-text-fill: white;
                                   -fx-border-radius: 8; -fx-background-radius: 8;
                                   -fx-padding: 0 16; -fx-cursor: hand;"/>
                </HBox>

                <ListView fx:id="lstIncidencias" VBox.vgrow="ALWAYS"
                          style="-fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                                 -fx-border-radius: 8; -fx-background-radius: 8;
                                 -fx-font-size: 13;"/>
            </VBox>
        </HBox>
    </VBox>
</AnchorPane>