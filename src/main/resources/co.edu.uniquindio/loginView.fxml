<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.viewControllers.LoginViewController"
            prefHeight="480.0" prefWidth="420.0"
            style="-fx-background-color: #f5f5f0;">

    <VBox alignment="CENTER" spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- Card central -->
        <VBox maxWidth="360" spacing="24"
              style="-fx-background-color: white;
                     -fx-border-color: #e0e0d8;
                     -fx-border-width: 0.5;
                     -fx-border-radius: 12;
                     -fx-background-radius: 12;
                     -fx-padding: 40 40 40 40;">

            <!-- Título -->
            <VBox spacing="4">
                <Label text="Iniciar sesión"
                       style="-fx-font-size: 22; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>
                <Label text="Ingresa tus datos para continuar"
                       style="-fx-font-size: 14; -fx-text-fill: #888780;"/>
            </VBox>

            <!-- Campos -->
            <VBox spacing="16">
                <VBox spacing="6">
                    <Label text="Correo electrónico"
                           style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                    <TextField fx:id="txtCorreo"
                               promptText="correo@ejemplo.com"
                               style="-fx-pref-height: 36; -fx-font-size: 14;
                                      -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 0 12;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Contraseña"
                           style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                    <PasswordField fx:id="txtContrasenia"
                                  promptText="Mínimo 6 caracteres"
                                  style="-fx-pref-height: 36; -fx-font-size: 14;
                                         -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                         -fx-background-radius: 8; -fx-padding: 0 12;"/>
                </VBox>
            </VBox>

            <!-- Mensaje de estado -->
            <Label fx:id="lblMensaje" text=""
                   wrapText="true"
                   style="-fx-font-size: 13; -fx-text-fill: #a32d2d;"/>

            <!-- Botones -->
            <VBox spacing="10">
                <Button text="Iniciar sesión"
                        onAction="#onIniciarSesion"
                        maxWidth="Infinity"
                        style="-fx-pref-height: 38; -fx-font-size: 14; -fx-font-weight: 500;
                               -fx-background-color: #2c2c2a; -fx-text-fill: white;
                               -fx-border-radius: 8; -fx-background-radius: 8;
                               -fx-cursor: hand;"/>

                <Button text="¿No tienes cuenta? Regístrate"
                        onAction="#onIrARegistro"
                        maxWidth="Infinity"
                        style="-fx-pref-height: 36; -fx-font-size: 13;
                               -fx-background-color: transparent;
                               -fx-text-fill: #5f5e5a;
                               -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                               -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>

        </VBox>
    </VBox>
</AnchorPane>
