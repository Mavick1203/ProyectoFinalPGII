<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.viewControllers.RegistroViewController"
            prefHeight="580.0" prefWidth="440.0"
            style="-fx-background-color: #f5f5f0;">

    <VBox alignment="CENTER" spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <VBox maxWidth="380" spacing="24"
              style="-fx-background-color: white;
                     -fx-border-color: #e0e0d8;
                     -fx-border-width: 0.5;
                     -fx-border-radius: 12;
                     -fx-background-radius: 12;
                     -fx-padding: 40 40 40 40;">

            <VBox spacing="4">
                <Label text="Crear cuenta"
                       style="-fx-font-size: 22; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>
                <Label text="Completa todos los campos para registrarte"
                       style="-fx-font-size: 14; -fx-text-fill: #888780;"/>
            </VBox>

            <VBox spacing="14">
                <VBox spacing="6">
                    <Label text="Nombre completo"
                           style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                    <TextField fx:id="txtNombre"
                               promptText="Tu nombre"
                               style="-fx-pref-height: 36; -fx-font-size: 14;
                                      -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 0 12;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Correo electrónico"
                           style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                    <TextField fx:id="txtCorreo"
                               promptText="correo@ejemplo.com"
                               style="-fx-pref-height: 36; -fx-font-size: 14;
                                      -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 0 12;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Teléfono"
                           style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                    <TextField fx:id="txtTelefono"
                               promptText="3001234567"
                               style="-fx-pref-height: 36; -fx-font-size: 14;
                                      -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 0 12;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Contraseña"
                           style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                    <PasswordField fx:id="txtContrasenia"
                                  promptText="Mínimo 6 caracteres"
                                  style="-fx-pref-height: 36; -fx-font-size: 14;
                                         -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                         -fx-background-radius: 8; -fx-padding: 0 12;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Confirmar contraseña"
                           style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                    <PasswordField fx:id="txtConfirmarContrasenia"
                                  promptText="Repite la contraseña"
                                  style="-fx-pref-height: 36; -fx-font-size: 14;
                                         -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                         -fx-background-radius: 8; -fx-padding: 0 12;"/>
                </VBox>
            </VBox>

            <Label fx:id="lblMensaje" text=""
                   wrapText="true"
                   style="-fx-font-size: 13; -fx-text-fill: #a32d2d;"/>

            <VBox spacing="10">
                <Button text="Registrarse"
                        onAction="#onRegistrar"
                        maxWidth="Infinity"
                        style="-fx-pref-height: 38; -fx-font-size: 14; -fx-font-weight: 500;
                               -fx-background-color: #2c2c2a; -fx-text-fill: white;
                               -fx-border-radius: 8; -fx-background-radius: 8;
                               -fx-cursor: hand;"/>

                <Button text="¿Ya tienes cuenta? Inicia sesión"
                        onAction="#onIrALogin"
                        maxWidth="Infinity"
                        style="-fx-pref-height: 36; -fx-font-size: 13;
                               -fx-background-color: transparent;
                               -fx-text-fill: #5f5e5a;
                               -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                               -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>

        </VBox>
    </VBox>
</AnchorPane>
