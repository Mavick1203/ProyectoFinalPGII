<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.viewControllers.RecintoViewController"
            prefHeight="700.0" prefWidth="900.0"
            style="-fx-background-color: #f5f5f0;">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: white;
                     -fx-border-color: #e0e0d8; -fx-border-width: 0 0 0.5 0;
                     -fx-padding: 14 24;">
            <VBox spacing="2">
                <Label text="Recintos y Zonas"
                       style="-fx-font-size: 18; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>
                <Label text="Gestiona recintos y sus zonas"
                       style="-fx-font-size: 13; -fx-text-fill: #888780;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Volver" onAction="#onVolver"
                    style="-fx-font-size: 13; -fx-background-color: transparent;
                           -fx-text-fill: #5f5e5a; -fx-border-color: #d3d1c7;
                           -fx-border-radius: 8; -fx-background-radius: 8;
                           -fx-pref-height: 32; -fx-cursor: hand;"/>
        </HBox>

        <HBox spacing="20" style="-fx-padding: 24;" VBox.vgrow="ALWAYS">

            <!-- Panel Recintos -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <Label text="Recintos"
                       style="-fx-font-size: 15; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                <VBox spacing="12"
                      style="-fx-background-color: white;
                             -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                             -fx-border-radius: 8; -fx-background-radius: 8;
                             -fx-padding: 16;">
                    <VBox spacing="6">
                        <Label text="Nombre"
                               style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                        <TextField fx:id="txtNombreRecinto" promptText="Nombre del recinto"
                                   style="-fx-pref-height: 34; -fx-font-size: 13;
                                          -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 0 10;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Dirección"
                               style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                        <TextField fx:id="txtDireccionRecinto" promptText="Dirección"
                                   style="-fx-pref-height: 34; -fx-font-size: 13;
                                          -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 0 10;"/>
                    </VBox>
                    <VBox spacing="6">
                        <Label text="Ciudad"
                               style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                        <TextField fx:id="txtCiudadRecinto" promptText="Ciudad"
                                   style="-fx-pref-height: 34; -fx-font-size: 13;
                                          -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 0 10;"/>
                    </VBox>
                    <Button text="Crear recinto" onAction="#onCrearRecinto"
                            style="-fx-pref-height: 34; -fx-font-size: 13; -fx-font-weight: 500;
                                   -fx-background-color: #2c2c2a; -fx-text-fill: white;
                                   -fx-border-radius: 8; -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>
                    <Label fx:id="lblEstadoRecinto" text=""
                           style="-fx-font-size: 12; -fx-text-fill: #0f6e56;"/>
                </VBox>

                <ListView fx:id="lstRecintos" VBox.vgrow="ALWAYS"
                          style="-fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                                 -fx-border-radius: 8; -fx-background-radius: 8;
                                 -fx-font-size: 13;"/>

                <Button text="Eliminar recinto" onAction="#onEliminarRecinto"
                        style="-fx-pref-height: 34; -fx-font-size: 13; -fx-font-weight: 500;
                               -fx-background-color: #a32d2d; -fx-text-fill: white;
                               -fx-border-radius: 8; -fx-background-radius: 8;
                               -fx-cursor: hand;"/>
            </VBox>

            <!-- Panel Zonas -->
            <VBox spacing="16" HBox.hgrow="ALWAYS">
                <Label text="Zonas del recinto seleccionado"
                       style="-fx-font-size: 15; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                <VBox spacing="12"
                      style="-fx-background-color: white;
                             -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                             -fx-border-radius: 8; -fx-background-radius: 8;
                             -fx-padding: 16;">
                    <VBox spacing="6">
                        <Label text="Nombre zona"
                               style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                        <TextField fx:id="txtNombreZona" promptText="Ej: VIP"
                                   style="-fx-pref-height: 34; -fx-font-size: 13;
                                          -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 0 10;"/>
                    </VBox>
                    <HBox spacing="12">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Capacidad"
                                   style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                            <TextField fx:id="txtCapacidadZona" promptText="100"
                                       style="-fx-pref-height: 34; -fx-font-size: 13;
                                              -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                              -fx-background-radius: 8; -fx-padding: 0 10;"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label text="Precio base"
                                   style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                            <TextField fx:id="txtPrecioBaseZona" promptText="80000"
                                       style="-fx-pref-height: 34; -fx-font-size: 13;
                                              -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                              -fx-background-radius: 8; -fx-padding: 0 10;"/>
                        </VBox>
                    </HBox>
                    <VBox spacing="6">
                        <Label text="Configuración"
                               style="-fx-font-size: 13; -fx-font-weight: 500;"/>
                        <ComboBox fx:id="cmbConfiguracion" maxWidth="Infinity"
                                  style="-fx-pref-height: 34; -fx-font-size: 13;"/>
                    </VBox>
                    <Button text="Agregar zona" onAction="#onCrearZona"
                            style="-fx-pref-height: 34; -fx-font-size: 13; -fx-font-weight: 500;
                                   -fx-background-color: #0f6e56; -fx-text-fill: white;
                                   -fx-border-radius: 8; -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>
                    <Label fx:id="lblEstadoZona" text=""
                           style="-fx-font-size: 12; -fx-text-fill: #0f6e56;"/>
                </VBox>

                <ListView fx:id="lstZonas" VBox.vgrow="ALWAYS"
                          style="-fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                                 -fx-border-radius: 8; -fx-background-radius: 8;
                                 -fx-font-size: 13;"/>

                <Button text="Eliminar zona" onAction="#onEliminarZona"
                        style="-fx-pref-height: 34; -fx-font-size: 13; -fx-font-weight: 500;
                               -fx-background-color: #a32d2d; -fx-text-fill: white;
                               -fx-border-radius: 8; -fx-background-radius: 8;
                               -fx-cursor: hand;"/>
            </VBox>

        </HBox>
        <Label fx:id="lblMensaje" text=""
               style="-fx-font-size: 13; -fx-padding: 0 24 12 24;"/>
    </VBox>
</AnchorPane>