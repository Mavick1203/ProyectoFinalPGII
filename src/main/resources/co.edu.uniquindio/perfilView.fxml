<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.viewControllers.PerfilViewController"
            prefHeight="620.0" prefWidth="600.0"
            style="-fx-background-color: #f5f5f0;">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- Encabezado -->
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: white;
                     -fx-border-color: #e0e0d8; -fx-border-width: 0 0 0.5 0;
                     -fx-padding: 14 24;">
            <VBox spacing="2">
                <Label text="Mi perfil"
                       style="-fx-font-size: 18; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>
                <Label text="Administra tu información personal"
                       style="-fx-font-size: 13; -fx-text-fill: #888780;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Volver" onAction="#onVolver"
                    style="-fx-font-size: 13; -fx-background-color: transparent;
                           -fx-text-fill: #5f5e5a; -fx-border-color: #d3d1c7;
                           -fx-border-radius: 8; -fx-background-radius: 8;
                           -fx-pref-height: 32; -fx-cursor: hand;"/>
        </HBox>

        <VBox spacing="20" style="-fx-padding: 24;">

            <!-- Datos personales -->
            <VBox spacing="16"
                  style="-fx-background-color: white;
                         -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                         -fx-border-radius: 8; -fx-background-radius: 8;
                         -fx-padding: 20;">
                <Label text="Datos personales"
                       style="-fx-font-size: 15; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Nombre"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <TextField fx:id="txtNombre"
                                   promptText="Tu nombre"
                                   style="-fx-pref-height: 36; -fx-font-size: 13;
                                          -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 0 12;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Teléfono"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <TextField fx:id="txtTelefono"
                                   promptText="3001234567"
                                   style="-fx-pref-height: 36; -fx-font-size: 13;
                                          -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 0 12;"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="Correo electrónico"
                           style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                    <TextField fx:id="txtCorreo"
                               promptText="correo@ejemplo.com"
                               style="-fx-pref-height: 36; -fx-font-size: 13;
                                      -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 0 12;"/>
                </VBox>

                <Button text="Actualizar perfil"
                        onAction="#onActualizarPerfil"
                        style="-fx-pref-height: 36; -fx-font-size: 13; -fx-font-weight: 500;
                               -fx-background-color: #2c2c2a; -fx-text-fill: white;
                               -fx-border-radius: 8; -fx-background-radius: 8;
                               -fx-padding: 0 18; -fx-cursor: hand;"/>
            </VBox>

            <!-- Cambio de contraseña -->
            <VBox spacing="16"
                  style="-fx-background-color: white;
                         -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                         -fx-border-radius: 8; -fx-background-radius: 8;
                         -fx-padding: 20;">
                <Label text="Cambiar contraseña"
                       style="-fx-font-size: 15; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Contraseña actual"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <PasswordField fx:id="txtContraseniaActual"
                                      promptText="Contraseña actual"
                                      style="-fx-pref-height: 36; -fx-font-size: 13;
                                             -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                             -fx-background-radius: 8; -fx-padding: 0 12;"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Nueva contraseña"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <PasswordField fx:id="txtNuevaContrasenia"
                                      promptText="Mínimo 6 caracteres"
                                      style="-fx-pref-height: 36; -fx-font-size: 13;
                                             -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                             -fx-background-radius: 8; -fx-padding: 0 12;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Confirmar contraseña"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <PasswordField fx:id="txtConfirmarContrasenia"
                                      promptText="Repite la contraseña"
                                      style="-fx-pref-height: 36; -fx-font-size: 13;
                                             -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                             -fx-background-radius: 8; -fx-padding: 0 12;"/>
                    </VBox>
                </HBox>

                <Button text="Cambiar contraseña"
                        onAction="#onCambiarContrasenia"
                        style="-fx-pref-height: 36; -fx-font-size: 13; -fx-font-weight: 500;
                               -fx-background-color: #2c2c2a; -fx-text-fill: white;
                               -fx-border-radius: 8; -fx-background-radius: 8;
                               -fx-padding: 0 18; -fx-cursor: hand;"/>
            </VBox>

            <Label fx:id="lblMensaje" text=""
                   wrapText="true"
                   style="-fx-font-size: 13; -fx-text-fill: #a32d2d;"/>
        </VBox>
    </VBox>
</AnchorPane>
