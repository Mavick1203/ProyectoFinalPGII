<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.viewControllers.CrearEventoViewController"
            prefHeight="620.0" prefWidth="640.0"
            style="-fx-background-color: #f5f5f0;">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: white;
                     -fx-border-color: #e0e0d8; -fx-border-width: 0 0 0.5 0;
                     -fx-padding: 14 24;">
            <VBox spacing="2">
                <Label text="Crear evento"
                       style="-fx-font-size: 18; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>
                <Label text="Completa los datos del nuevo evento"
                       style="-fx-font-size: 13; -fx-text-fill: #888780;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="← Volver" onAction="#onVolver"
                    style="-fx-font-size: 13; -fx-background-color: transparent;
                           -fx-text-fill: #5f5e5a; -fx-border-color: #d3d1c7;
                           -fx-border-radius: 8; -fx-background-radius: 8;
                           -fx-pref-height: 32; -fx-cursor: hand;"/>
        </HBox>

        <VBox spacing="20" style="-fx-padding: 24;">

            <VBox spacing="16"
                  style="-fx-background-color: white;
                         -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                         -fx-border-radius: 8; -fx-background-radius: 8;
                         -fx-padding: 20;">

                <Label text="Información del evento"
                       style="-fx-font-size: 15; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Nombre"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <TextField fx:id="txtNombre"
                                   promptText="Nombre del evento"
                                   style="-fx-pref-height: 36; -fx-font-size: 13;
                                          -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 0 12;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Ciudad"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <TextField fx:id="txtCiudad"
                                   promptText="Ciudad"
                                   style="-fx-pref-height: 36; -fx-font-size: 13;
                                          -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 0 12;"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="Descripción"
                           style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                    <TextArea fx:id="txtDescripcion"
                              promptText="Descripción del evento"
                              prefHeight="80"
                              style="-fx-font-size: 13;
                                     -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                     -fx-background-radius: 8; -fx-padding: 8 12;"/>
                </VBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Categoría"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <ComboBox fx:id="cmbCategoria" maxWidth="Infinity"
                                  style="-fx-pref-height: 36; -fx-font-size: 13;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Recinto"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <ComboBox fx:id="cmbRecinto" maxWidth="Infinity"
                                  style="-fx-pref-height: 36; -fx-font-size: 13;"/>
                    </VBox>
                </HBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Fecha"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <DatePicker fx:id="dateFecha" maxWidth="Infinity"
                                    style="-fx-pref-height: 36; -fx-font-size: 13;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Hora (HH:mm)"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <TextField fx:id="txtHora"
                                   promptText="18:00"
                                   style="-fx-pref-height: 36; -fx-font-size: 13;
                                          -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 0 12;"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="Políticas"
                           style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                    <TextArea fx:id="txtPoliticas"
                              promptText="Políticas del evento"
                              prefHeight="60"
                              style="-fx-font-size: 13;
                                     -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                     -fx-background-radius: 8; -fx-padding: 8 12;"/>
                </VBox>

                <Button text="Crear evento"
                        onAction="#onCrearEvento"
                        style="-fx-pref-height: 36; -fx-font-size: 13; -fx-font-weight: 500;
                               -fx-background-color: #2c2c2a; -fx-text-fill: white;
                               -fx-border-radius: 8; -fx-background-radius: 8;
                               -fx-padding: 0 18; -fx-cursor: hand;"/>
            </VBox>

            <Label fx:id="lblMensaje" text=""
                   wrapText="true"
                   style="-fx-font-size: 13; -fx-text-fill: #a32d2d;"/>
        </VBox>
    </VBox>
</AnchorPane>