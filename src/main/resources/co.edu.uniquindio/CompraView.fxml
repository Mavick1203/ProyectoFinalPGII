<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.viewControllers.CompraViewController"
            prefHeight="680.0" prefWidth="700.0"
            style="-fx-background-color: #f5f5f0;">

    <VBox spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

        <!-- Encabezado -->
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color: white;
                     -fx-border-color: #e0e0d8; -fx-border-width: 0 0 0.5 0;
                     -fx-padding: 14 24;">
            <VBox spacing="2">
                <Label text="Comprar entrada"
                       style="-fx-font-size: 18; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>
                <Label fx:id="lblEvento" text=""
                       style="-fx-font-size: 13; -fx-text-fill: #888780;"/>
            </VBox>
        </HBox>

        <!-- Contenido en dos columnas -->
        <HBox spacing="20" style="-fx-padding: 24;" VBox.vgrow="ALWAYS">

            <!-- Columna izquierda: selección -->
            <VBox spacing="20" HBox.hgrow="ALWAYS">

                <!-- Selección de zona y asiento -->
                <VBox spacing="16"
                      style="-fx-background-color: white;
                             -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                             -fx-border-radius: 8; -fx-background-radius: 8;
                             -fx-padding: 20;">
                    <Label text="Selección de asiento"
                           style="-fx-font-size: 15; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                    <VBox spacing="6">
                        <Label text="Zona"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <ComboBox fx:id="cmbZona" maxWidth="Infinity"
                                  onAction="#onZonaSeleccionada"
                                  style="-fx-pref-height: 36; -fx-font-size: 13;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Asiento"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <ComboBox fx:id="cmbAsiento" maxWidth="Infinity"
                                  style="-fx-pref-height: 36; -fx-font-size: 13;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Tipo de entrada"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <ComboBox fx:id="cmbTipoEntrada" maxWidth="Infinity"
                                  style="-fx-pref-height: 36; -fx-font-size: 13;"/>
                    </VBox>
                </VBox>

                <!-- Servicios adicionales -->
                <VBox spacing="12"
                      style="-fx-background-color: white;
                             -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                             -fx-border-radius: 8; -fx-background-radius: 8;
                             -fx-padding: 20;">
                    <Label text="Servicios adicionales"
                           style="-fx-font-size: 15; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                    <CheckBox fx:id="chkParqueadero" text="Parqueadero  (+$20.000)"
                              style="-fx-font-size: 13; -fx-text-fill: #2c2c2a;"/>
                    <CheckBox fx:id="chkSeguro" text="Seguro de cancelación  (+$15.000)"
                              style="-fx-font-size: 13; -fx-text-fill: #2c2c2a;"/>
                    <CheckBox fx:id="chkMerchandising" text="Merchandising  (+$30.000)"
                              style="-fx-font-size: 13; -fx-text-fill: #2c2c2a;"/>
                    <CheckBox fx:id="chkAccesoPreferencial" text="Acceso preferencial  (+$25.000)"
                              style="-fx-font-size: 13; -fx-text-fill: #2c2c2a;"/>
                    <CheckBox fx:id="chkVIP" text="Acceso VIP  (+$50.000)"
                              style="-fx-font-size: 13; -fx-text-fill: #2c2c2a;"/>
                </VBox>

            </VBox>

            <!-- Columna derecha: pago y resumen -->
            <VBox spacing="20" prefWidth="260">

                <!-- Resumen -->
                <VBox spacing="12"
                      style="-fx-background-color: white;
                             -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                             -fx-border-radius: 8; -fx-background-radius: 8;
                             -fx-padding: 20;">
                    <Label text="Resumen"
                           style="-fx-font-size: 15; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                    <Label fx:id="lblTotal" text="Total: —"
                           style="-fx-font-size: 20; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                    <Button text="Crear compra"
                            onAction="#onCrearCompra"
                            maxWidth="Infinity"
                            style="-fx-pref-height: 36; -fx-font-size: 13; -fx-font-weight: 500;
                                   -fx-background-color: #2c2c2a; -fx-text-fill: white;
                                   -fx-border-radius: 8; -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>
                </VBox>

                <!-- Método de pago -->
                <VBox spacing="12"
                      style="-fx-background-color: white;
                             -fx-border-color: #e0e0d8; -fx-border-width: 0.5;
                             -fx-border-radius: 8; -fx-background-radius: 8;
                             -fx-padding: 20;">
                    <Label text="Método de pago"
                           style="-fx-font-size: 15; -fx-font-weight: 500; -fx-text-fill: #1a1a18;"/>

                    <VBox spacing="6">
                        <Label text="Método"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <ComboBox fx:id="cmbMetodoPago" maxWidth="Infinity"
                                  style="-fx-pref-height: 36; -fx-font-size: 13;"/>
                    </VBox>

                    <VBox spacing="6">
                        <Label text="Datos de pago"
                               style="-fx-font-size: 13; -fx-font-weight: 500; -fx-text-fill: #444441;"/>
                        <TextField fx:id="txtDatosPago"
                                   promptText="N° tarjeta o cuenta"
                                   style="-fx-pref-height: 36; -fx-font-size: 13;
                                          -fx-border-color: #d3d1c7; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-padding: 0 10;"/>
                    </VBox>

                    <Button text="Pagar"
                            onAction="#onPagar"
                            maxWidth="Infinity"
                            style="-fx-pref-height: 36; -fx-font-size: 13; -fx-font-weight: 500;
                                   -fx-background-color: #0f6e56; -fx-text-fill: white;
                                   -fx-border-radius: 8; -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>

                    <Button text="Cancelar"
                            onAction="#onCancelar"
                            maxWidth="Infinity"
                            style="-fx-pref-height: 34; -fx-font-size: 13;
                                   -fx-background-color: transparent;
                                   -fx-text-fill: #5f5e5a; -fx-border-color: #d3d1c7;
                                   -fx-border-radius: 8; -fx-background-radius: 8;
                                   -fx-cursor: hand;"/>
                </VBox>

                <Label fx:id="lblMensaje" text=""
                       wrapText="true"
                       style="-fx-font-size: 13; -fx-text-fill: #a32d2d;"/>
            </VBox>
        </HBox>
    </VBox>
</AnchorPane>
